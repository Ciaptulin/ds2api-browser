# DS2API Browser 环境配置
# 复制此文件为 .env 并填入实际值

# 多账号配置，用分号分隔
# 格式: email:password[:name[:proxy]]
DS2API_ACCOUNTS=user1@gmail.com:password1:账号1;user2@gmail.com:password2:账号2

# API 密钥（逗号分隔）
DS2API_KEYS=sk-test123456

# 管理员密钥
DS2API_ADMIN_KEY=admin

# 服务端口与监听地址
DS2API_PORT=5001
DS2API_HOST=0.0.0.0

# 无头浏览器模式
DS2API_HEADLESS=true

# 真人行为模拟
DS2API_HUMANIZE=true

# 每账号最大并发请求数
DS2API_MAX_CONCURRENT=3

# 最大同时活跃浏览器数（= 最大并发数）
DS2API_MAX_ACTIVE_BROWSERS=50

# 请求超时（毫秒）
DS2API_TIMEOUT=60000

# 全局代理（可选）
# DS2API_DEFAULT_PROXY=http://127.0.0.1:7890
